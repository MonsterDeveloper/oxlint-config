{
  "name": "@cto_of_everything/oxlint-config",
  "version": "1.0.0",
  "description": "Oxlint config used by the CTO of Everything.",
  "sideEffects": false,
  "type": "module",
  "packageManager": "bun@1.3.13",
  "homepage": "https://github.com/MonsterDeveloper/oxlint-config",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MonsterDeveloper/oxlint-config.git"
  },
  "license": "GPL-3.0-only",
  "author": "Andrei Bobkov <me@ctoofeverything.dev>",
  "scripts": {
    "update": "bunx npm-check-updates -ui --reject bun",
    "format": "oxfmt"
  },
  "publishConfig": {
    "provenance": true
  },
  "files": [
    "configs/**"
  ],
  "exports": {
    "./base": "./configs/base.json",
    "./react": "./configs/react.json"
  },
  "peerDependencies": {
    "oxlint": "^1.63.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0"
  }
}
